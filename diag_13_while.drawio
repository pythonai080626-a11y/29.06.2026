        </mxCell>
        <mxCell id="XUfGQVMmywGm9-DNn-Jg-60" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;13&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;input numbers until number == 99&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;9&lt;/span&gt;&lt;/div&gt;&lt;div&gt;calculate the sum of all of the numbers&lt;/div&gt;&lt;div&gt;(except 999)&lt;/div&gt;&lt;div&gt;1, 10, 999 =&amp;gt; sum = 11&lt;/div&gt;&lt;/div&gt;" vertex="1">
