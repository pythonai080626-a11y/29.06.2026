        <mxCell id="XUfGQVMmywGm9-DNn-Jg-71" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;14&lt;/div&gt;&lt;div&gt;input a, b&lt;br&gt;a &amp;gt; 0 also b &amp;gt; 0&lt;/div&gt;&lt;div&gt;a = 5 , b = 3&lt;/div&gt;&lt;div&gt;output = 15&lt;/div&gt;&lt;div&gt;not allow to use *&lt;/div&gt;&lt;div&gt;5 + 5 + 5&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2 * 4 =&amp;nbsp;&lt;/div&gt;&lt;div&gt;2 + 2 + 2 + 2&lt;/div&gt;&lt;div&gt;Solution: start with sum=0, then&lt;/div&gt;&lt;div&gt;add a to sum , b times&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="260" x="510" y="160" as="geometry" />
